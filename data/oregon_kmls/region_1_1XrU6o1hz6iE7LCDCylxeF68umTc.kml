            <value>https://lh3.googleusercontent.com/umsh/AN6v0v4UYqvA_gXFJVPjX33vr128V4LdHD8N7vtTPNfeR-CL0bOsJgD_ZNh0gYIKUk49X5oyRQKSWwKjgu6Tzh2T6eXiVDh5CjvLm7VeGhiRRr_142DgU88Xc9YkYbHcalsppEOCJvaNt4FSqWCI28DvKb-CPxWKsUgp</value>

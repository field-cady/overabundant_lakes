            -122.095184,44.766785,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Breitenbush River - Bridge at USFS Rd 4685</name>
        <styleUrl>#icon-53-nodesc</styleUrl>
